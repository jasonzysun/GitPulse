{
  "name": "gitpulse",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build:release": "tauri build --config src-tauri/tauri.release.conf.json",
    "version:patch": "node ./scripts/bump-version.mjs patch",
    "version:minor": "node ./scripts/bump-version.mjs minor",
    "version:major": "node ./scripts/bump-version.mjs major",
    "version:set": "node ./scripts/set-version.mjs",
    "build:patch": "node ./scripts/bump-version.mjs patch && npm run tauri:build:release",
    "build:minor": "node ./scripts/bump-version.mjs minor && npm run tauri:build:release",
    "build:major": "node ./scripts/bump-version.mjs major && npm run tauri:build:release",
    "release:win": "node ./scripts/publish-release.mjs patch",
    "release:win:patch": "node ./scripts/publish-release.mjs patch",
    "release:win:minor": "node ./scripts/publish-release.mjs minor",
    "release:win:major": "node ./scripts/publish-release.mjs major",
    "release:win:set": "node ./scripts/publish-release.mjs --set",
    "release:win:current": "node ./scripts/publish-release.mjs current"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
