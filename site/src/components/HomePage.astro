---
import "../styles/global.css";
import {
  localeLabels,
  locales,
  type Locale,
  type PageContent,
} from "../i18n/content";

interface Props {
  locale: Locale;
  content: PageContent;
}

const { locale, content } = Astro.props;

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const asset = (path: string) => `${base}${path.replace(/^\/+/, "")}`;
const localePath = (targetLocale: Locale) => `${base}${targetLocale}/`;
const absoluteUrl = (path: string) => new URL(path, Astro.site ?? "https://goldenzqqq.github.io").toString();

const releaseUrl = "https://github.com/GoldenZqqq/GitPulse/releases/latest";
const repoUrl = "https://github.com/GoldenZqqq/GitPulse";
const canonicalUrl = absoluteUrl(localePath(locale));
const defaultUrl = absoluteUrl(base);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{content.title}</title>
    <meta name="description" content={content.description} />
    <meta property="og:title" content="GitPulse" />
    <meta property="og:description" content={content.ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteUrl(asset("assets/brand-light.png"))} />
    <meta property="og:locale" content={locale === "zh-CN" ? "zh_CN" : "en_US"} />
    {locales.filter((target) => target !== locale).map((target) => (
      <meta property="og:locale:alternate" content={target === "zh-CN" ? "zh_CN" : "en_US"} />
    ))}
    <link rel="canonical" href={canonicalUrl} />
    {locales.map((target) => (
      <link rel="alternate" hreflang={target} href={absoluteUrl(localePath(target))} />
    ))}
    <link rel="alternate" hreflang="x-default" href={defaultUrl} />
    <link rel="icon" type="image/png" href={asset("assets/favicon.png")} />
  </head>
  <body>
    <header class="site-header" aria-label={content.navAriaLabel}>
      <a class="brand" href={localePath(locale)} aria-label={content.homeAriaLabel}>
        <picture>
          <source media="(prefers-color-scheme: dark)" srcset={asset("assets/brand-dark.png")} />
          <img src={asset("assets/brand-light.png")} alt="GitPulse" width="142" height="40" />
        </picture>
      </a>
      <nav class="nav-links" aria-label={content.navAriaLabel}>
        {content.nav.map((item) => (
          <a href={`#${item.id}`}>{item.label}</a>
        ))}
      </nav>
      <div class="header-actions">
        <nav class="language-switch" aria-label={content.languageLabel}>
          {locales.map((target) => (
            <a
              class:list={["language-link", target === locale && "active"]}
              href={localePath(target)}
              hreflang={target}
              lang={target}
              aria-current={target === locale ? "page" : undefined}
              data-locale-choice={target}
            >
              {localeLabels[target]}
            </a>
          ))}
        </nav>
        <a class="header-action" href={repoUrl}>{content.githubLabel}</a>
      </div>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <video
          class="hero-video"
          autoplay
          muted
          loop
          playsinline
          poster={asset("assets/gitpulse-demo.gif")}
          aria-label={content.demoAriaLabel}
        >
          <source src={asset("assets/gitpulse-demo.mp4")} type="video/mp4" />
        </video>
        <div class="hero-scrim" aria-hidden="true"></div>
        <div class="hero-content">
          <p class="eyebrow">{content.hero.eyebrow}</p>
          <h1 id="hero-title">GitPulse</h1>
          <p class="hero-copy">{content.hero.copy}</p>
          <div class="hero-actions" aria-label={content.hero.actionsLabel}>
            <a class="button primary" href={releaseUrl}>{content.hero.primaryAction}</a>
            <a class="button secondary" href={repoUrl}>{content.hero.secondaryAction}</a>
          </div>
          <dl class="hero-facts" aria-label={content.hero.factsLabel}>
            {content.hero.facts.map((fact) => (
              <div>
                <dt>{fact.value}</dt>
                <dd>{fact.label}</dd>
              </div>
            ))}
          </dl>
        </div>
      </section>

      <section class="section intro" id="workflow" aria-labelledby="workflow-title">
        <div class="section-heading">
          <p class="eyebrow">{content.workflow.eyebrow}</p>
          <h2 id="workflow-title">{content.workflow.title}</h2>
        </div>
        <div class="workflow-grid">
          {content.workflow.steps.map((item, index) => (
            <article class="workflow-step">
              <span class="step-index">{String(index + 1).padStart(2, "0")}</span>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section demo-section" aria-labelledby="demo-title">
        <div class="section-heading compact">
          <p class="eyebrow">{content.demo.eyebrow}</p>
          <h2 id="demo-title">{content.demo.title}</h2>
        </div>
        <div class="demo-frame">
          <video controls playsinline poster={asset("assets/gitpulse-demo.gif")}>
            <source src={asset("assets/gitpulse-demo.mp4")} type="video/mp4" />
          </video>
        </div>
      </section>

      <section class="section feature-band" id="features" aria-labelledby="features-title">
        <div class="section-heading">
          <p class="eyebrow">{content.features.eyebrow}</p>
          <h2 id="features-title">{content.features.title}</h2>
        </div>
        <div class="feature-grid">
          {content.features.items.map((item) => (
            <article class="feature-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section privacy" id="privacy" aria-labelledby="privacy-title">
        <div>
          <p class="eyebrow">{content.privacy.eyebrow}</p>
          <h2 id="privacy-title">{content.privacy.title}</h2>
        </div>
        <div class="privacy-copy">
          <p>{content.privacy.body}</p>
          <a class="text-link" href={`${repoUrl}#${content.privacy.linkHash}`}>{content.privacy.linkLabel}</a>
        </div>
      </section>

      <section class="section download" id="download" aria-labelledby="download-title">
        <div class="download-copy">
          <p class="eyebrow">{content.download.eyebrow}</p>
          <h2 id="download-title">{content.download.title}</h2>
          <p>{content.download.body}</p>
        </div>
        <div class="download-actions">
          <a class="button primary dark" href={releaseUrl}>{content.download.primaryAction}</a>
          <a class="button secondary dark" href={`${repoUrl}#${content.download.quickStartHash}`}>
            {content.download.secondaryAction}
          </a>
        </div>
      </section>

      <section class="section faq" aria-labelledby="faq-title">
        <div class="section-heading compact">
          <p class="eyebrow">{content.faq.eyebrow}</p>
          <h2 id="faq-title">{content.faq.title}</h2>
        </div>
        <div class="faq-list">
          {content.faq.items.map((item) => (
            <details>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <span>GitPulse</span>
      <a href={repoUrl}>{content.githubLabel}</a>
      <a href={releaseUrl}>{content.footer.releasesLabel}</a>
    </footer>

    <script is:inline>
      (() => {
        const storageKey = "gitpulse-site-locale";
        document.querySelectorAll("[data-locale-choice]").forEach((link) => {
          link.addEventListener("click", () => {
            try {
              localStorage.setItem(storageKey, link.dataset.localeChoice || "");
            } catch {
              // Ignore storage errors in private browsing or locked-down browsers.
            }

            if (window.location.hash) {
              link.href = link.href.split("#")[0] + window.location.hash;
            }
          });
        });
      })();
    </script>
  </body>
</html>
