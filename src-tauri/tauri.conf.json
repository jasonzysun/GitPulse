{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitPulse",
  "version": "0.1.0",
  "identifier": "com.goldenzqqq.gitpulse",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GitPulse",
        "width": 1180,
        "height": 780,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://openlist.hzqnb.site/gitpulse/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc5RUY1RkU5NDhFQ0ZDMTAKUldRUS9PeEk2Vi92ZVhXOEx0ajZjM0l1czBDaXo5anl0eVlhOThHSmV5RnRWV1pVMEF0aGxXa3UK"
    }
  }
}
