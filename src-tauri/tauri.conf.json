{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitPulse",
  "version": "0.4.1",
  "identifier": "com.goldenzqqq.gitpulse",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GitPulse",
        "width": 1180,
        "height": 900,
        "minWidth": 980,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/GoldenZqqq/GitPulse/releases/latest/download/gitpulse-latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc5RUY1RkU5NDhFQ0ZDMTAKUldRUS9PeEk2Vi92ZVhXOEx0ajZjM0l1czBDaXo5anl0eVlhOThHSmV5RnRWV1pVMEF0aGxXa3UK"
    }
  }
}
