# Tauri updater signing key
TAURI_SIGNING_PRIVATE_KEY_PATH=C:\Users\YourName\.gitpulse\updater\gitpulse-updater.key
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=replace-with-your-signing-password

# GitHub Release publish target
GITPULSE_GITHUB_TOKEN=github_pat_xxx
GITPULSE_GITHUB_REPO=GoldenZqqq/GitPulse
# GITPULSE_GITHUB_API_BASE_URL=https://api.github.com
# GITPULSE_GITHUB_WEB_BASE_URL=https://github.com

# Optional release notes override
# GITPULSE_RELEASE_NOTES=GitPulse 0.1.0 发布
# GITPULSE_RELEASE_NOTES_FILE=release-notes/v0.1.0.md

# GitHub Release publish flow
# release 脚本会要求当前工作区先保持干净，
# 成功构建后自动提交版本号文件、推送分支与 vX.Y.Z tag，
# 然后创建或更新 GitHub Release，并上传安装包 / .sig / gitpulse-latest.json
