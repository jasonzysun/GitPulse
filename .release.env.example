# OpenList WebDAV upload target
OPENLIST_WEBDAV_URL=https://your-openlist-host.example/dav/
OPENLIST_WEBDAV_USERNAME=your-upload-username
OPENLIST_WEBDAV_PASSWORD=replace-with-your-password
OPENLIST_PUBLIC_ORIGIN=https://your-openlist-host.example
OPENLIST_PATH=/your/remote/dir

# Tauri updater signing key
TAURI_SIGNING_PRIVATE_KEY_PATH=C:\Users\YourName\.gitpulse\updater\gitpulse-updater.key
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=replace-with-your-signing-password

# Published latest.json endpoint
GITPULSE_MANIFEST_PUBLIC_URL=https://your-openlist-host.example/gitpulse/latest.json
GITPULSE_MANIFEST_SSH_HOST=your.server.host
GITPULSE_MANIFEST_REMOTE_PATH=/path/to/nginx/html/gitpulse/latest.json

# Optional release notes override
# GITPULSE_RELEASE_NOTES=GitPulse 0.1.0 发布
# GITPULSE_RELEASE_NOTES_FILE=release-notes/v0.1.0.md

# Optional GitHub Release publish
# 开启后，release 脚本会要求当前工作区先保持干净，
# 成功构建后自动提交版本号文件、推送分支与 vX.Y.Z tag，
# 然后创建或更新 GitHub Release，并上传安装包 / .sig / gitpulse-latest.json
GITPULSE_GITHUB_RELEASE_ENABLED=false
# GITPULSE_GITHUB_TOKEN=github_pat_xxx
# GITPULSE_GITHUB_REPO=GoldenZqqq/GitPulse
# GITPULSE_GITHUB_API_BASE_URL=https://api.github.com
